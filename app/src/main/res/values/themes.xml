<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base do app (claro, para manter a identidade visual consistente) -->
    <style name="Base.Theme.TocaDosPeludos" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/green_container</item>
        <item name="colorOnPrimaryContainer">@color/on_green_container</item>
        <item name="colorSecondary">@color/amber</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:colorBackground">@color/grey</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>

    <style name="Theme.TocaDosPeludos" parent="Base.Theme.TocaDosPeludos" />

    <!-- ===== Tipografia ===== -->
    <style name="Text.Heading" parent="">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Section" parent="">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Body" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <!-- ===== Botões ===== -->
    <style name="PrimaryButton">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="OutlineButton">
        <item name="android:background">@drawable/bg_button_outline</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="DangerButton" parent="PrimaryButton">
        <item name="android:background">@drawable/bg_button_danger</item>
    </style>

    <!-- ===== Campos de texto ===== -->
    <style name="FieldInput">
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <!-- ===== Card ===== -->
    <style name="Card">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">20dp</item>
        <item name="android:elevation">2dp</item>
    </style>
</resources>
