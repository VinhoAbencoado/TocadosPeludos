<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey"
    android:padding="20dp"
    tools:context=".CreateEventActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp">

        <Button
            android:id="@+id/btnBackEvent"
            style="@style/OutlineButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Novo evento"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/dark_green"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título *"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEventTitle"
            style="@style/FieldInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex.: Feira de Adoção"
            android:inputType="textCapSentences"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data *"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEventDate"
            style="@style/FieldInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex.: 20 mai"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local *"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEventLocation"
            style="@style/FieldInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex.: Praça Central"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição *"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEventDescription"
            style="@style/FieldInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Detalhes do evento"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top|start"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSaveEvent"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publicar evento" />

    </LinearLayout>
</ScrollView>
